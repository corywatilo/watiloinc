# PostHog — project 30022
# Copy this file to .env.local and fill in real values.

# Client (exposed to the browser; safe to commit only as a placeholder)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server (server-only; never exposed to the browser)
POSTHOG_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com

# Fonts — Cloudflare Worker that proxies R2 with origin-based access control.
# The worker enforces "watilo.com / *.vercel.app / localhost / secret-key" only.
NEXT_PUBLIC_FONT_HOST=https://watilo-fonts.watiloinc.workers.dev

# Server-only secret. Set this locally so dev requests still pass the worker
# check if localhost gets removed from the allow-list. DO NOT set in production
# — the Origin check is the production guard. Must match the value uploaded to
# the worker via `wrangler secret put FONT_ACCESS_KEY`.
FONT_ACCESS_KEY=
